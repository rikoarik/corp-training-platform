{
  "name": "corp-training-platform",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/frontend",
    "apps/backend"
  ],
  "scripts": {
    "dev:frontend": "npm --workspace apps/frontend run dev",
    "dev:backend": "npm --workspace apps/backend run dev",
    "build": "npm run build --workspace apps/frontend && npm run build --workspace apps/backend",
    "lint": "npm run lint --workspace apps/frontend && npm run lint --workspace apps/backend",
    "prisma:generate": "npm --workspace apps/backend run prisma:generate",
    "prisma:migrate": "npm --workspace apps/backend run prisma:migrate",
    "prisma:seed": "npm --workspace apps/backend run prisma:seed"
  }
}